# ============================================
# ENVIRONMENT CONFIGURATION - WINDOWS USERS
# ============================================
#
# Instructions:
# 1. Copy this file and rename it to .env
# 2. Update the paths below if needed
# 3. Make sure model files exist in the specified location
# ============================================

# ----------------- MongoDB Connection -----------------
# Standard local MongoDB connection
# No change needed unless using a different MongoDB host/port
mongo_uri = mongodb://localhost:27017/

# ----------------- AI Model Paths -----------------
# IMPORTANT: Update these paths to match where you placed your model files
# You can use either:
# 1. Relative paths (from this project folder) - RECOMMENDED
# 2. Absolute paths (full path on your computer)

# OPTION 1: Relative path (if model folder is in this project directory)
MODEL_PATH = model/gemma-3-27B-it-QAT-Q4_0.gguf
MMPROJ_PATH = model/mmproj-model-f16.gguf

# OPTION 2: Absolute path (uncomment and update if using absolute paths)
# Replace the example below with your actual path
# MODEL_PATH = C:\Users\YourUsername\Documents\AI-generated-image-and-document-metadata_UWA\model\gemma-3-27B-it-QAT-Q4_0.gguf
# MMPROJ_PATH = C:\Users\YourUsername\Documents\AI-generated-image-and-document-metadata_UWA\model\mmproj-model-f16.gguf

# ============================================
# NOTES:
# ============================================
#
# - Model files must be in the specified location
# - File names must match exactly (case-sensitive)
# - Use forward slashes (/) or double backslashes (\\) for Windows paths
# - The .env file should be in the same folder as this file
# - Do NOT commit the actual .env file with sensitive data
# ============================================
